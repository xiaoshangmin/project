<!--pages/detail/detail.wxml-->
<view class="page">
	<view class="weui-panel weui-panel_access">
		<view class="weui-panel__bd">
			<view class="list">
				<view class="weui-flex">
					<view class="weui-flex__item fac">
						<view class="avatar mr-15">
							<image src="{{content.user.avatar}}" mode="aspectFill" style="width: 100rpx; height: 100rpx;border-radius: 50%;"></image>
						</view>
						<view class="info">
							<view class="username">{{content.user.username}}</view>
							<view class="intro">{{content.user.intro}}</view>
						</view>
					</view>
				</view>
				<view class="weui-flex">
					<view class="weui-flex__item">
						<view class="content">{{content.content}}</view>
					</view>
				</view>
				<view class="weui-flex">
					<view class="weui-flex__item">
						<view class="grids">
							<view class="grid" wx:for="{{content.pictures}}" wx:key="index" wx:for-item="url">
								<image src="{{url}}" data-src="{{url}}" mode="aspectFill" bindtap='previewImage'></image>
							</view>
						</view>
					</view>
				</view>
				<view class="weui-flex">
					<view class="weui-flex__item">
						<view class="address">{{content.poi.address}}</view>
					</view>
				</view>
				<view class="weui-flex footer">
					<view class="weui-flex__item">
						<view class="like fac">
							<image src="../../images/like.png" style="width:40rpx;height:40rpx"></image>
							<view class="num mlr-5">
								{{content.like}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="comment fac">
							<image src="../../images/comment.png" style="width:40rpx;height:40rpx"></image>
							<view class="num mlr-5">
								{{content.comment}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="collect fac">
							<image src="../../images/collect.png" style="width:40rpx;height:40rpx"></image>
							<view class="num mlr-5">
								{{content.collect}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="share fac">
							<image src="../../images/share.png" style="width:40rpx;height:40rpx"></image>
							<view class="num mlr-5">
								{{content.share}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="more fac">
							<image src="../../images/more.png" style="width:40rpx;height:40rpx"></image>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>

	<view class="weui-panel weui-panel_access" id="comment">
		<view class="weui-panel__hd">热门评论</view>
		<view class="weui-panel__bd" wx:for="{{hotComments}}" wx:key="index" wx:for-item="hot">
			<view class="list">
				<view class="weui-flex">
					<view class="weui-flex__item fac comment">
						<view class="avatar mr-15">
							<image src="{{hot.user.avatar}}" mode="aspectFill" style="width: 100rpx; height: 100rpx;border-radius: 50%;"></image>
						</view>
						<view class="info">
							<view class="username">{{hot.user.username}}</view>
							<view class="intro">11小时前</view>
						</view>
					</view>
					<view>
						<view class="like fac">
							<view class="num mlr-5">
								99
							</view>
							<image src="../../images/like.png" style="width:40rpx;height:40rpx"></image>
						</view>
					</view>
				</view>
				<view class="weui-flex comment-content">
					<view class="weui-flex__item">
						<view class="content">{{hot.content}}</view>
					</view>
				</view>
				<view class="weui-flex comment-content">
					<view class="weui-flex__item">
						<view class="grids">
							<view class="grid">
								<image src="{{hot.pictures}}" data-src="{{hot.pictures}}" mode="aspectFill" bindtap='previewCommentImage'></image>
							</view>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>

	<view class="weui-panel weui-panel_access">
		<view class="weui-panel__hd">最新评论</view>
		<view class="weui-panel__bd list" wx:for="{{comments}}" wx:key="index" wx:for-item="comment">
			<view class="weui-flex">
				<view class="weui-flex__item fac">
					<view class="avatar mr-15">
						<image src="{{comment.user.avatar}}" mode="aspectFill" style="width: 100rpx; height: 100rpx;border-radius: 50%;"></image>
					</view>
					<view class="info">
						<view class="username">{{comment.user.username}}</view>
						<view class="intro">11小时前</view>
					</view>
				</view>
			</view>
			<view class="weui-flex comment-content">
				<view class="weui-flex__item">
					<view class="content">{{comment.content}}</view>
				</view>
			</view>
			<view class="weui-flex comment-content">
				<view class="weui-flex__item">
					<view class="grids">
						<view class="grid">
							<image src="{{comment.pictures}}" data-src="{{comment.pictures}}" mode="aspectFill" bindtap='previewCommentImage'></image>
						</view>
					</view>
				</view>
			</view>
		</view>


	</view>

</view>