<view class="page">
	<view class="container">
		<view class="panel">
			<view class="main">
				<view class="fac">
					<view class="avatar">
						<image src="{{content.user.avatar}}" mode="aspectFill" style="width: 80rpx; height: 80rpx;border-radius: 50%;" bindlongpress="saveImage"></image>
					</view>
					<view class="info">
						<view class="username">{{content.user.username}}</view>
						<view class="intro">{{content.user.intro}}</view>
					</view>
				</view>
				<van-row>
					<van-col span="23">
						<view class="content">{{content.content}}</view>
					</van-col>
				</van-row>
				<van-row>
					<van-col span="20">
						<view class="grids">
							<view class="grid" wx:for="{{content.pictures}}" wx:key="url" wx:for-item="url">
								<image src="{{url}}" data-src="{{url}}" data-id="{{idx}}" mode="aspectFill" catchtap='previewImage'></image>
							</view>
						</view>
					</van-col>
				</van-row>
				<van-row>
					<view class="address">{{content.poi.address}}</view>
				</van-row>
				<van-row>
					<van-col span="4">
						<view class="like fac">
							<image src="../../images/like.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{content.like}}
							</view>
						</view>
					</van-col>
					<van-col span="4">
						<view class="comment fac">
							<image src="../../images/comment.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{content.comment}}
							</view>
						</view>
					</van-col>
					<van-col span="4">
						<view class="collect fac">
							<image src="../../images/collect.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{content.collect}}
							</view>
						</view>
					</van-col>
					<van-col span="4">
						<view class="share fac">
							<image src="../../images/share.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{content.share}}
							</view>
						</view>
					</van-col>
					<view>
						<view class="more fac">
							<image src="../../images/more.png" style="width:40rpx;height:40rpx"></image>
						</view>
					</view>
				</van-row>
			</view>
		</view>

		<view class="panel">
			<van-cell title="热门评论" />
			<view class="comments" wx:for="{{hotComments}}" wx:key="*this" wx:for-item="item">
				<view class="hot-comment">
					<view class="fac">
						<view class="avatar">
							<image src="{{content.user.avatar}}" mode="aspectFill" style="width: 80rpx; height: 80rpx;border-radius: 50%;" bindlongpress="saveImage"></image>
						</view>
						<view class="info">
							<view class="username">{{item.user.username}}</view>
							<view class="comment-time">1小时前</view>
						</view>
						<view class="prase fac">
							<view class="comment-num">
								{{item.like}}
							</view>
							<image src="../../images/like.png" style="width:30rpx;height:30rpx"></image>
						</view>
					</view>
					<van-row custom-class="comment-content">
						<van-col span="24">
							<view class="content">{{item.content}}</view>
						</van-col>
						<van-col span="24">
							<!-- 图片宽高动态计算 -->
							<image src="{{item.pictures}}" data-src="{{item.pictures}}" mode="widthFix" catchtap='previewCommentImage'></image>
						</van-col>
					</van-row>
				</view>
			</view>
		</view>


		<view class="panel">
			<van-cell title="最新评论" />
			<view class="comments" wx:for="{{hotComments}}" wx:key="*this" wx:for-item="item">
				<view class="hot-comment">
					<view class="fac">
						<view class="avatar">
							<image src="{{content.user.avatar}}" mode="aspectFill" style="width: 80rpx; height: 80rpx;border-radius: 50%;" bindlongpress="saveImage"></image>
						</view>
						<view class="info">
							<view class="username">{{item.user.username}}</view>
							<view class="comment-time">1小时前</view>
						</view>
						<view class="prase fac">
							<view class="comment-num">
								{{item.like}}
							</view>
							<image src="../../images/like.png" style="width:30rpx;height:30rpx"></image>
						</view>
					</view>
					<van-row custom-class="comment-content">
						<van-col span="24">
							<view class="content">{{item.content}}</view>
						</van-col>
						<van-col span="24">
							<!-- 图片宽高动态计算 -->
							<image src="{{item.pictures}}" data-src="{{item.pictures}}" mode="widthFix" catchtap='previewCommentImage'></image>
						</van-col>
					</van-row>
				</view>
			</view>
		</view>
	</view>
</view>