/* pages/home/home.wxss */
.page {
  background-color: #ededed;
}

.container {
  /* margin-bottom: 70px; */
}

.panel:first-child {
  margin-top: 0;
}

.panel,
.ad {
  background-color: #fff;
  margin-top: 10rpx;
  /* padding-top: 20rpx; */
}

.main,
.comment-list-area {
  margin-left: 25rpx;
  margin-right: 40rpx;
  padding-bottom: 30rpx;
}

.comment-list-area {
  border-bottom: 1rpx solid #ebedf0;
}

.comments {
  padding-top: 20rpx;
  width: 100%;
}

.fac {
  display: flex;
  align-items: center;
}


.operate {
  margin-top: 25rpx;
  height: 70rpx;
}

.like-area,
.comment-area,
.share-area,
/* .empty-area, */
.more-area {
  width: 25%;
}


.operate image {
  width: 46rpx;
  height: 46rpx;
}

.info {
  margin-bottom: 20rpx;
}

.userinfo {
  width: 65%;
}

.avatar {
  width: 15%;
}

.prase {
  width: 20%;
  justify-content: flex-end;
}

.main .username {
  color: #404040;
  font-size: 30rpx;
  font-weight: 400;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.hot-comment .username {
  color: #717171;
  font-size: 28rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.intro,
.comment-time {
  color: #c0c0c0;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.address {
  font-size: 24rpx;
  color: #b4b4b4;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.content {
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  color: #404040;
}


.group-area {
  height: 50rpx;
  color: #4ba6ed;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f2f4;
  border-radius: 50rpx;
  padding: 0rpx 15rpx;
}

.group-name{
  font-size: 25rpx;
  font-weight: 600;
  margin-left: 5rpx;
}


.comment-content {
  margin-left: 105rpx;

}

.comment-content image {
  width: 200rpx;
}

.grids {
  position: relative;
  overflow: hidden;
  width: 665rpx;
}

.grid {
  position: relative;
  float: left;
  box-sizing: border-box;
  margin-right: 10rpx;
}

.grid image {
  max-width: 300rpx;
  /* max-height: 300rpx; */
}


.more {
  float: right;
}

.num {
  color: #969696;
  font-size: 26rpx;
  font-weight: 300;
  margin-left: 10rpx;
}

button[plain] {
  border: 0;
  width: auto;
  margin-left: 0;
  margin-right: 0;
  padding-left: 0;
  padding-right: 0;
  line-height: 0rpx;
}

.comment-num {
  color: #969696;
  margin-right: 8rpx;
  font-size: 26rpx;
}

.placeholder {
  height: 65px;
}

.replay {
  width: 100%;
  position: fixed;
  color: black;
  z-index: 50;
  background-color: #fff;
  padding: 10rpx 10rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #ededed;
  display: flex;
  align-items: center;
  /* padding-left: 25rpx; */
}

.replay-input {
  flex: 7;
}

.replay-image {
  padding-left: 14px;
}

.replay-input-img-btn-area,
.replay-input-btn-area {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  flex: 1;
}