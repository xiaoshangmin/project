/* pages/home/home.wxss */
.page {
  background-color: #ededed;
}


.panel:first-child {
  margin-top: 0;
}

.panel {
  background-color: #fff;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.main,
.hot-comment {
  margin-left: 25rpx;
  margin-right: 40rpx;
  padding-bottom: 30rpx;
  padding-top: 20rpx;
}

.comments {
  width: 100%;
  border-bottom: 1px solid #dbdbdb;
}

.fac {
  display: flex;
  align-items: center;
}
.operate image {
  width: 43rpx;
  height: 43rpx;
}
.info {
  width: 65%;
}

.avatar {
  width: 15%;
}

.prase {
  width: 20%;
  justify-content: flex-end;
}

.main .username {
  color: #404040;
  font-size: 30rpx;
  font-weight: 400;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.hot-comment .username {
  color: #717171;
  font-size: 28rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.intro,.comment-time {
  color: #c0c0c0;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.address {
  font-size: 24rpx;
  color: #b4b4b4;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.content {
  margin-top: 15rpx;
  margin-bottom: 15rpx;
  font-size: 32rpx;
  color: #404040;
}

.comment-content {
  margin-left: 105rpx;
  
}
.comment-content image{
  width: 200rpx;
}

.grids {
  position: relative;
  overflow: hidden;
  width: 565rpx;
}

.grid {
  position: relative;
  float: left;
  box-sizing: border-box;
  margin-right: 10rpx;
}

.grid image {
  width: 150rpx;
  height: 150rpx;
}


.more {
  float: right;
}

.num {
  color: #969696;
  margin-left: 5rpx;
}
button[plain] {
  border: 0;
  width: auto;
  margin-left: 0;
  margin-right: 0;
  padding-left: 0;
  padding-right: 0;
  line-height: 0rpx;
}
.comment-num {
  color: #969696;
  margin-right: 8rpx;
  font-size: 26rpx;
}

.footer {
  margin-top: 22rpx;
  margin-bottom: 25rpx;
}