/* pages/groupContent/groupContent.wxss */
page {
  background-color: #ededed;
}

.container {
  padding-bottom: 53px;
}

.panel:first-child {
  margin-top: 0;
}

.panel {
  background-color: #fff;
  margin-bottom: 15rpx;
  padding-top: 20rpx;
}

.main {
  margin-left: 25rpx;
  margin-right: 40rpx;
  padding-bottom: 30rpx;
}

.group-info {
  display: flex;
  align-items: center;
  justify-content: center; 
  height: 300rpx;
  width: 100%; 
  /* filter: brightness(0.60); */
  z-index: -1;
  background-image: url('http://cdn.wowyou.cc/user_bg_01.png');
  background-repeat: no-repeat;
  /* background-size: cover; */
  /* background-position: center; */
  border-radius: 5px;
}

.name {
  font-size: 40rpx;
  text-align: center;
  color: #fff;
  font-weight: 500;
}

.heat {
  width: 300rpx;
  font-size: 25rpx;
  color: #fff;
  font-weight: 400;
  display: flex;
  justify-content: center;
  align-items: center;
}

.posts {
  flex: 1;
  text-align: center;
}

.follow {
  flex: 1;
  text-align: center;
}

.info {
  margin-bottom: 20rpx;
}

.operate image {
  width: 46rpx;
  height: 46rpx;
}

.fac {
  display: flex;
  align-items: center;
}

.avatar {
  margin-right: 15rpx;
}

.username {
  color: #404040;
  font-size: 30rpx;
}

.intro {
  color: #bfbfbf;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 590rpx;
}

.poi {
  height: 70rpx;
  display: inline-flex;
  align-items: center;
}

.address {
  font-size: 24rpx;
  color: #b4b4b4;
}

.group-area {
  height: 50rpx;
  color: #4ba6ed;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f2f4;
  border-radius: 50rpx;
  padding: 0rpx 15rpx;
}

.group-name {
  font-size: 25rpx;
  font-weight: 600;
  margin-left: 5rpx;
}

.operate {
  margin-top: 25rpx;
  height: 70rpx;
}

.like-area,
.comment-area,
.share-area,
.more-area {
  width: 20%;
}

.content {
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  color: #404040;
}

.images {
  display: flex;
  align-items: space-around;
}

button[plain] {
  border: 0;
  width: auto;
  margin-left: 0;
  margin-right: 0;
  padding-left: 0;
  padding-right: 0;
  line-height: 0rpx;
}

.grids {
  position: relative;
  overflow: hidden;
  width: 665rpx;
}

.grid {
  position: relative;
  float: left;
  box-sizing: border-box;
  margin-right: 10rpx;
}

.grid image {
  max-width: 300rpx;
}


.more {
  float: right;
}

.num {
  color: #969696;
  font-size: 26rpx;
  font-weight: 300;
  margin-left: 10rpx;
}


.hot {
  width: 100%;
  height: auto;
  background-color: #f2f2f2;
  border-radius: 10rpx;
  padding: 10rpx 15rpx;
  font-size: 25rpx;
  color: #8a8a8a;
}

.hot-header {
  display: flex;
  justify-content: space-between;
  line-height: 40rpx;
}


.hot-content {
  margin: 10rpx 0rpx;
  padding-right: 5rpx;
  line-height: 40rpx;
}

.hot-nickname {
  color: #313131;
  display: inline;
}