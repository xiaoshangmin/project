<view class="page">
	<view class="container">
		<view class="weui-panel weui-panel_access" wx:for="{{list}}" wx:key="index" wx:for-index="idx" wx:for-item="item" data-cid="{{item.id}}" bindtap="toDetail">
			<view class="weui-panel__bd list">
				<view class="weui-flex">
					<view class="weui-flex__item fac">
						<view class="avatar">
							<image src="{{item.user.avatar}}" mode="aspectFill" style="width: 100rpx; height: 100rpx;border-radius: 50%;"></image>
						</view>
						<view class="info">
							<view class="username">{{item.user.username}}</view>
							<view class="intro">{{item.user.intro}}</view>
						</view>
					</view>
				</view>
				<view class="weui-flex">
					<view class="weui-flex__item">
						<view class="content">{{item.content}}</view>
					</view>
				</view>
				<view class="weui-flex">
					<view class="weui-flex__item">
						<view class="grids">
							<view class="grid" wx:for="{{item.urls}}" wx:key="url" wx:for-item="url">
								<image src="{{url}}" data-src="{{url}}" data-id="{{idx}}" mode="aspectFill" catchtap='previewImage'></image>
							</view>
						</view>
					</view>
				</view>
				<view class="weui-flex">
					<view class="weui-flex__item">
						<view class="address">{{item.poi.address}}</view>
					</view>
				</view>
				<view class="weui-flex footer">
					<view class="weui-flex__item">
						<view class="like operate">
							<image src="../../images/like.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{item.like}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="comment operate">
							<image src="../../images/comment.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{item.comment}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="collect operate">
							<image src="../../images/collect.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{item.collect}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="share operate">
							<image src="../../images/share.png" style="width:40rpx;height:40rpx"></image>
							<view class="num">
								{{item.share}}
							</view>
						</view>
					</view>
					<view class="weui-flex__item">
						<view class="more operate">
							<image src="../../images/more.png" style="width:40rpx;height:40rpx"></image>
						</view>
					</view>
				</view>
			</view>
		</view>
	</view>
</view>