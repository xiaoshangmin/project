<view class="page">
	<view class="container">
		<!-- 浮动的发布按钮 -->
		<view class="publish-btn">
			<van-image width="90rpx" height="90rpx" src="../../../../images/publish_active.png" round fit="cover" bindtap="toPublish" />
		</view>

		<van-dialog title="授权确认" message="微信授权登录" show="{{ show }}" show-cancel-button confirm-button-open-type="getUserInfo" bind:close="onClose" bind:getuserinfo="getUserInfo">
		</van-dialog>

		<view class="panel" wx:for="{{list}}" wx:key="index" wx:for-index="idx" wx:for-item="item">
			<view class="main">
				<view class="info" data-cid="{{item.id}}" bindtap="toDetail">
					<view class="fac">
						<view class="avatar">
							<van-image width="80rpx" height="80rpx" src="{{item.user.avatar}}" round fit="cover" />
						</view>
						<view class="userinfo">
							<view class="username">{{item.user.username}}</view>
							<view class="intro">{{item.user.intro}}</view>
						</view>
					</view>
					<van-row>
						<van-col span="23">
							<view class="content">{{item.content}}</view>
						</van-col>
					</van-row>
					<van-row>
						<van-col span="20">
							<view class="grids">
								<view class="grid" wx:for="{{item.pictures}}" wx:key="key" wx:for-item="picture">
									<van-image width="150rpx" height="150rpx" src="{{picture.smallPicUrl}}" fit="cover" catchtap='previewImage' data-src="{{picture.middlePicUrl}}" data-cid="{{item.id}}" />
								</view>
							</view>
						</van-col>
					</van-row>
				</view>
				<!-- <van-row>
					<view class="address">{{item.poi.address}}</view>
				</van-row> -->
				<van-row custom-class="operate">
					<van-col span="6">
						<view class="like fac" catchtap="like" data-cid="{{item.id}}">
							<image src="../../images/like.png"></image>
							<view class="num">
								{{item.like}}
							</view>
						</view>
					</van-col>
					<van-col span="6">
						<view class="comment fac" catchtap="comment" data-cid="{{item.id}}">
							<image src="../../images/comment.png"></image>
							<view class="num">
								{{item.comment}}
							</view>
						</view>
					</van-col>
					<van-col span="6">
						<view class="share fac">
							<button open-type="share" plain="true" data-cid="{{item.id}}" data-user="{{item.user.username}}">
								<image src="../../images/share.png"></image>
							</button>
							<view class="num">
								{{item.share}}
							</view>
						</view>
					</van-col>
					<!-- <view>
						<view class="more fac" catchtap="more" data-cid="{{item.id}}">
							<image src="../../images/more.png"></image>
						</view>
					</view> -->
				</van-row>
			</view>
		</view>
	</view>
</view>