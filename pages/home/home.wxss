/* pages/home/home.wxss */
.page {
  background-color: #ededed;
}

.container {
  padding-bottom: 53px;
}

.panel:first-child {
  margin-top: 0;
}

.panel {
  background-color: #fff;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.main {
  margin-left: 25rpx;
  margin-right: 40rpx;
  padding-bottom: 30rpx;
}

.operate image {
  width: 50rpx;
  height: 50rpx;
}

.fac {
  display: flex;
  align-items: center;
}

.avatar {
  margin-right: 15rpx;
}

.username {
  color: #404040;
  font-size: 30rpx;
}

.intro {
  color: #bfbfbf;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 590rpx;
}

.address {
  font-size: 24rpx;
  color: #b4b4b4;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.content {
  margin-top: 15rpx;
  margin-bottom: 15rpx;
  font-size: 32rpx;
  color: #404040;
}

.images {
  display: flex;
  align-items: space-around;
}

.grids {
  position: relative;
  overflow: hidden;
  width: 565rpx;
}

.grid {
  position: relative;
  float: left;
  box-sizing: border-box;
  margin-right: 10rpx;
}

.grid image {
  width: 150rpx;
  height: 150rpx;
}


.more {
  float: right;
}

.num {
  color: #969696;
  margin-left: 5rpx;
}

.publish-btn {
  position: fixed;
  bottom: 220rpx;
  right: 50rpx;
  display: flex;
  width: 90rpx;
  height: 90rpx;
  justify-content: center;
}


.footer {
  margin-top: 22rpx;
  margin-bottom: 25rpx;
}